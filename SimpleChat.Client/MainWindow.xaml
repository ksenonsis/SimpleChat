<Window x:Class="SimpleChat.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleChat — Клиент"
        Height="520" Width="700"
        MinHeight="400" MinWidth="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Панель подключения -->
            <RowDefinition Height="Auto"/>
            <!-- Основная область -->
            <RowDefinition Height="*"/>
            <!-- Поле ввода -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ Панель подключения ══════════════ -->
        <GroupBox Grid.Row="0" Header="Подключение" Margin="0,0,0,8" Padding="8">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Сервер:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="txtHost" Width="120" Text="127.0.0.1"
                         VerticalContentAlignment="Center" Padding="4,3"/>

                <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                <TextBox x:Name="txtPort" Width="55" Text="5000"
                         VerticalContentAlignment="Center" Padding="4,3"/>

                <TextBlock Text="Ваше имя:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                <TextBox x:Name="txtName" Width="120"
                         VerticalContentAlignment="Center" Padding="4,3"/>

                <Button x:Name="btnConnect" Content="Подключиться"
                        Width="110" Margin="10,0,0,0" Padding="0,4"
                        Click="btnConnect_Click"/>

                <Button x:Name="btnDisconnect" Content="Отключиться"
                        Width="110" Margin="6,0,0,0" Padding="0,4"
                        IsEnabled="False"
                        Click="btnDisconnect_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- ══════════════ Чат + список пользователей ══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <!-- Список сообщений -->
            <GroupBox Grid.Column="0" Header="Сообщения" Margin="0,0,6,0">
                <ListBox x:Name="lstMessages"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       TextWrapping="Wrap"
                                       Padding="2,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Список пользователей -->
            <GroupBox Grid.Column="1" Header="Онлайн">
                <ListBox x:Name="lstUsers" BorderThickness="0"/>
            </GroupBox>
        </Grid>

        <!-- ══════════════ Поле ввода ══════════════ -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtMessage"
                     Grid.Column="0"
                     IsEnabled="False"
                     Padding="6,5"
                     VerticalContentAlignment="Center"
                     KeyDown="txtMessage_KeyDown"/>

            <Button x:Name="btnSend"
                    Grid.Column="1"
                    Content="Отправить"
                    Width="100" Margin="6,0,0,0" Padding="0,5"
                    IsEnabled="False"
                    Click="btnSend_Click"/>
        </Grid>
    </Grid>
</Window>
